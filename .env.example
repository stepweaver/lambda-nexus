# Local-safe default. Mock mode does not use DATABASE_URL.
CEREBRO_DATA_SOURCE=mock
DATABASE_URL=

# Local/dev Postgres mode. Do not use production or VPS credentials here.
# CEREBRO_DATA_SOURCE=postgres
# DATABASE_URL=postgres://USER:PASSWORD@localhost:5432/DB_NAME

# Set to true only for local development databases that use self-signed TLS.
# PGSSL_ALLOW_SELF_SIGNED=false
